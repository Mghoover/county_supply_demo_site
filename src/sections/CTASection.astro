---
import CTAButton from "../components/common/CTAButton.astro";
import SectionHeader from "../components/common/SectionHeader.astro";

const { heading } = Astro.props;
---
<section class="content-section">
  <div class="shell">
    <div class="cta-panel">
      <SectionHeader {...heading} />
      <div class="hero-actions">
        <CTAButton href={heading.primaryCta.href} label={heading.primaryCta.label} />
        <CTAButton href={heading.secondaryCta.href} label={heading.secondaryCta.label} variant="secondary" />
      </div>
    </div>
  </div>
</section>
