---
import { business } from "../../config/business";
import { nav } from "../../config/navigation";
import { theme } from "../../config/theme";
import { withBase } from "../../utils/paths";
---
<header class="site-header">
  <div class="shell header-shell">
    <a class="brand-mark" href={withBase("/")} aria-label={`${business.name} home`}>
      <img src={withBase(theme.logo)} alt={business.name} />
      <div>
        <strong>{business.name}</strong>
        <span>{business.tagline}</span>
        {business.divisionOf && <small class="brand-division">Division of {business.divisionOf}</small>}
      </div>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={withBase(item.link)}>{item.label}</a>
      ))}
    </nav>
    {business.phone && <a class="header-phone" href={`tel:${business.phone}`}>{business.phone}</a>}
  </div>
</header>
