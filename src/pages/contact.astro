---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/footer/Footer.astro";
import CTASection from "../sections/CTASection.astro";
import HoursSection from "../sections/HoursSection.astro";
import PageHero from "../components/common/PageHero.astro";
import LocationCard from "../components/cards/LocationCard.astro";
import InfoGrid from "../components/common/InfoGrid.astro";
import { business } from "../config/business";
import { site } from "../config/site";

const contactOptions = [
  { label: "Phone", value: business.phone },
  { label: "Email", value: business.email },
  { label: "Primary Yard", value: "Florence, SC" },
];
---
<BaseLayout
  pageTitle={site.pages.contact.title}
  pageDescription={site.pages.contact.description}
  pageKeywords={site.pages.contact.keywords}
>
  <Header />
  <main>
    <PageHero {...site.pageHeroes.contact} />
    <section class="content-section">
      <div class="shell">
        <div class="split-callout">
          <div>
            <p class="section-eyebrow">Contact Options</p>
            <h2>Connect with a Florence SC building supply yard that looks ready to help</h2>
            <p class="section-description">
              The contact page keeps the core paths clear: call the Florence location, request a quote, or visit the yard for pickup and product support.
            </p>
          </div>
          <InfoGrid items={contactOptions} columns={3} />
        </div>
      </div>
    </section>
    <section class="content-section alt-surface">
      <div class="shell">
        <div class="section-header">
          <p class="section-eyebrow">Locations</p>
          <h2>County Supply and Lake City Lumber</h2>
          <p class="section-description">
            Use the Florence yard for daily material runs and the Lake City division connection for broader sourcing support.
          </p>
        </div>
        <div class="stack-layout">
          {business.locations.map((location) => <LocationCard location={location} />)}
        </div>
      </div>
    </section>
    <HoursSection
      heading={{
        eyebrow: "Yard Hours",
        title: "Primary Florence location hours",
        description: "Demo hours are centered on the Florence yard so local customers know when to call or stop in.",
      }}
    />
    <CTASection heading={site.home.sectionContent.cta} />
  </main>
  <Footer />
</BaseLayout>
