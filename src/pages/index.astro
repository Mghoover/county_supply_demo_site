---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/footer/Footer.astro";
import HeroSection from "../sections/HeroSection.astro";
import ServicesSection from "../sections/ServicesSection.astro";
import TestimonialsSection from "../sections/TestimonialsSection.astro";
import CTASection from "../sections/CTASection.astro";
import LocationsPreviewSection from "../sections/LocationsPreviewSection.astro";
import QuotePreviewSection from "../sections/QuotePreviewSection.astro";
import { site } from "../config/site";
import { services } from "../content/services";
import { contractorServices } from "../content/contractor-services";
import { testimonials } from "../content/testimonials";

const sectionComponents = {
  hero: HeroSection,
  services: ServicesSection,
  contractorServices: ServicesSection,
  testimonials: TestimonialsSection,
  cta: CTASection,
  locationsPreview: LocationsPreviewSection,
  quotePreview: QuotePreviewSection,
};

const sectionProps = {
  hero: { hero: site.home.hero },
  services: { heading: site.home.sectionContent.services, items: services },
  contractorServices: {
    heading: site.home.sectionContent.contractorServices,
    items: contractorServices,
  },
  testimonials: { heading: site.home.sectionContent.testimonials, items: testimonials },
  cta: { heading: site.home.sectionContent.cta },
  locationsPreview: { heading: site.home.sectionContent.locationsPreview },
  quotePreview: { heading: site.home.sectionContent.quotePreview },
};
---
<BaseLayout
  pageTitle={site.pages.home.title}
  pageDescription={site.pages.home.description}
  pageKeywords={site.pages.home.keywords}
>
  <Header />
  <main>
    {site.home.sectionOrder.map((sectionKey) => {
      const Section = sectionComponents[sectionKey];
      return Section ? <Section {...sectionProps[sectionKey]} /> : null;
    })}
  </main>
  <Footer />
</BaseLayout>
