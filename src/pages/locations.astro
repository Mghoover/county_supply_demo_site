---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/footer/Footer.astro";
import CTASection from "../sections/CTASection.astro";
import PageHero from "../components/common/PageHero.astro";
import LocationCard from "../components/cards/LocationCard.astro";
import { business } from "../config/business";
import { site } from "../config/site";
---
<BaseLayout
  pageTitle={site.pages.locations.title}
  pageDescription={site.pages.locations.description}
  pageKeywords={site.pages.locations.keywords}
>
  <Header />
  <main>
    <PageHero {...site.pageHeroes.locations} />
    <section class="content-section">
      <div class="shell">
        <div class="section-header">
          <p class="section-eyebrow">County Supply Locations</p>
          <h2>Florence and Lake City location cards with map embeds</h2>
          <p class="section-description">
            Each location card includes a Google Maps-style embed, address information, and a clear path to directions or quote follow-up.
          </p>
        </div>
        <div class="stack-layout">
          {business.locations.map((location) => <LocationCard location={location} />)}
        </div>
      </div>
    </section>
    <CTASection heading={site.home.sectionContent.cta} />
  </main>
  <Footer />
</BaseLayout>
